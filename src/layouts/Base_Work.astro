---
import Nav from "../components/Nav.astro";
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title = "Works",
  description = "The works of Sean Jefferson M. Calaoagan, a.k.a. XianShizukana",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-pink-700">
    <Nav />
    <section class="px-5 py-30 lg:p-30">
      <h1
        class="mb-5 text-center text-4xl font-extrabold text-pink-100 lg:text-6xl"
      >
        {title}
      </h1>
      <section class="grid gap-4 xl:grid-cols-2">
        <slot />
      </section>
    </section>
  </body>
</html>
