---
import Card from "../components/Card.astro";
import Layout from "../layouts/Base_Work.astro";

const cronos_desc = [
  "A simple, QR Code based attendance monitoring system. Includes a filtering system to check present students on selected days. Made as part of my team's requirement for our class, Programming Languages 2.",
];

const workshop_desc = [
  "Taught at a workshop organized by my team, C-Purasu. I spoke about the basic features of Ren'Py, and created a simple visual novel for demonstration. Spoke to Grade 11 CIIT students on the 28th as well as school visitors on the 29th of November. This was done for our class, Seminars & Workshop.",
];
---

<Layout title="Senior High School">
  <Card
    title="Shiro's Fantastical Website"
    date="May 10, 2025"
    buttonLink="Hello!"
  />
  <Card
    title="C.R.O.N.O.S"
    date="December 1, 2024"
    buttonLink="https://github.com/Xian-Shizukana/cronos/tree/main"
    buttonTitle="View Github Repository"
    image="work-cronos.png"
    list={cronos_desc}
  />
  <Card
    title="C-Purasu Workshop"
    date="November 28-29, 2024"
    buttonLink="https://github.com/Xian-Shizukana/workshoptemplate/tree/main"
    buttonTitle="View Workshop Tutorial Repository"
    image="work-seminar.JPG"
    list={workshop_desc}
  />
</Layout>
